{
  "name": "telegram-markdown-html",
  "version": "0.1.0",
  "description": "Render Markdown into Telegram-safe HTML with chunking support",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.build.json --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "markdown-it": "^14.1.1",
    "markdown-it-container": "^4.0.0",
    "node-html-parser": "^7.1.0"
  },
  "keywords": [
    "telegram",
    "markdown",
    "html",
    "bot",
    "renderer"
  ]
}
