TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: comma-separated Telegram user IDs that may DM the bot.
# Example: 123456789,987654321
ALLOWED_USER_IDS=

# Optional: if set, users in this group/supergroup can interact with the bot.
# The bot must be in the group to verify membership.
# Example: -1001234567890
ALLOWED_GROUP_ID=

# Optional: working directory pi should operate in.
# Defaults to the current project directory.
PI_WORKDIR=

# Optional: explicit pi model in provider/model-id format.
# Example: anthropic/claude-sonnet-4-5
PI_MODEL=

# Optional: pi thinking level.
# Allowed: off, minimal, low, medium, high, xhigh
PI_THINKING_LEVEL=

# Optional: extra comma-separated extension file or directory paths for pi.
# Standard pi extension discovery still works.
PI_EXTENSION_PATHS=
