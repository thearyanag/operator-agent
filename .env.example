TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: bot username without @. Required for Mini App group install links
# and useful for mention detection in groups.
TELEGRAM_BOT_USERNAME=

# Optional: comma-separated Telegram user IDs that may DM the bot.
# Example: 123456789,987654321
ALLOWED_USER_IDS=

# Optional: if set, users in this group/supergroup can interact with the bot.
# The bot must be in the group to verify membership.
# Example: -1001234567890
ALLOWED_GROUP_ID=

# Optional: stream private-DM assistant text through Telegram sendRichMessageDraft.
# Defaults to true. Other Telegram surfaces use Rich Message sends/edits.
ENABLE_TELEGRAM_NATIVE_STREAMING=

# Optional: enable Telegram Business / Chat Automation messages.
# Users still control connection and chat scope in Telegram Settings > Chat Automation.
# Defaults to true. Set to false to ignore Business automation updates.
ENABLE_TELEGRAM_BUSINESS_AUTOMATION=

# Optional: comma-separated Telegram user IDs whose connected Business accounts may use Personal Operator.
# Empty means all Telegram users who connect the bot through Chat Automation are allowed.
TELEGRAM_BUSINESS_ALLOWED_OWNER_IDS=

# Optional: run Business automation without sending owner-facing draft notifications.
# Defaults to false.
TELEGRAM_BUSINESS_DRY_RUN=

# Optional: Operator system-of-record Postgres URL.
# This creates/uses the operator schema for conversations, observations,
# policy decisions, outputs, summaries, memory, sessions, and audit events.
# Docker Compose defaults this to postgresql://operator:operator@postgres:5432/operator.
OPERATOR_DATABASE_URL=

# Optional: local Docker Compose Postgres settings.
# POSTGRES_PORT is the host port; the app container still uses postgres:5432.
POSTGRES_USER=operator
POSTGRES_PASSWORD=operator
POSTGRES_DB=operator
POSTGRES_PORT=55432

# Optional: stable UUID for the person who owns this Operator instance.
# Defaults to a local placeholder UUID. Set this explicitly in production.
OPERATOR_OWNER_ID=

# Optional: comma-separated Telegram user IDs that are allowed to use owner-wide Operator tools.
# This is separate from OPERATOR_OWNER_ID, which is only the internal Postgres owner UUID.
OPERATOR_OWNER_TELEGRAM_IDS=

# Optional: bearer/query token for the native Telegram Mini App control panel.
OPERATOR_CONTROL_PANEL_TOKEN=

# Optional: run-scoped Telegram context artifact directory.
# Docker stores this durably in /data/operator-context and exposes it to pi at /app/operator-context.
# Defaults to ./.operator/context for native local runs.
OPERATOR_CONTEXT_DIR=

# Optional: working directory pi should operate in.
# Defaults to the current project directory.
PI_WORKDIR=

# Required for the default Anthropic model unless Anthropic auth is already configured in pi settings.
ANTHROPIC_API_KEY=

# Optional: explicit pi model in provider/model-id format.
# Defaults to anthropic/claude-sonnet-4-5
# In PI_PROVIDER=openrouter mode, OPENROUTER_MODEL takes precedence over PI_MODEL.
PI_MODEL=

# Optional: product-level provider choice. Leave empty to use the default Anthropic model.
# Allowed: openrouter, openai-codex
PI_PROVIDER=

# OpenRouter mode: user provides an API key and model string.
# OPENROUTER_MODEL may be either google/gemini-... or openrouter/google/gemini-...
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# OpenAI Codex mode: user provides the credential fields normally stored in ~/.pi/agent/auth.json.
# OPENAI_CODEX_MODEL is optional and defaults to gpt-5.3-codex.
OPENAI_CODEX_MODEL=
OPENAI_CODEX_ACCESS_TOKEN=
OPENAI_CODEX_REFRESH_TOKEN=
OPENAI_CODEX_EXPIRES_AT_MS=
OPENAI_CODEX_ACCOUNT_ID=

# Alternative OpenAI Codex input: either the openai-codex credential object or the full auth.json object.
OPENAI_CODEX_AUTH_JSON=

# Optional: pi thinking level.
# Allowed: off, minimal, low, medium, high, xhigh
PI_THINKING_LEVEL=

# Optional: extra comma-separated extension file or directory paths for pi.
# Standard pi extension discovery still works.
PI_EXTENSION_PATHS=

# Optional: path to the operator system prompt markdown file.
# Relative paths are resolved from PI_WORKDIR.
# Defaults to prompts/system-prompt.md
PI_SYSTEM_PROMPT_PATH=

# Optional: custom directory for persisted per-chat pi sessions.
# Defaults to ./.pi/telegram-sessions
PI_SESSION_DIR=

# Optional: canonical operator runtime state database.
# Defaults to ./.operator/state/operator.sqlite
# SQLite remains a local compatibility store while the Operator Postgres path
# replaces it gradually.
OPERATOR_STATE_DB_PATH=

# Optional: comma-separated directories that pi may send as Telegram file attachments
# via the telegram_queue_attachment tool. Relative paths are resolved from PI_WORKDIR.
# Defaults to PI_WORKDIR only.
TELEGRAM_ATTACHMENT_ROOTS=

# Required for the local Postgres MCP package if enabled in .mcp.json.
DATABASE_URL=

# Required for the local Datadog MCP package if enabled in .mcp.json.
DD_API_KEY=
DD_APP_KEY=

# Optional Datadog site override, for example datadoghq.com or us5.datadoghq.com.
DD_SITE=
