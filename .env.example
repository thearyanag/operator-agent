TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: comma-separated Telegram user IDs that may DM the bot.
# Example: 123456789,987654321
ALLOWED_USER_IDS=

# Optional: if set, users in this group/supergroup can interact with the bot.
# The bot must be in the group to verify membership.
# Example: -1001234567890
ALLOWED_GROUP_ID=

# Optional: working directory pi should operate in.
# Defaults to the current project directory.
PI_WORKDIR=

# Optional: explicit pi model in provider/model-id format.
# Example: anthropic/claude-sonnet-4-5
PI_MODEL=

# Optional: pi thinking level.
# Allowed: off, minimal, low, medium, high, xhigh
PI_THINKING_LEVEL=

# Optional: extra comma-separated extension file or directory paths for pi.
# Standard pi extension discovery still works.
PI_EXTENSION_PATHS=

# Optional: path to the operator system prompt markdown file.
# Relative paths are resolved from PI_WORKDIR.
# Defaults to prompts/system-prompt.md
PI_SYSTEM_PROMPT_PATH=

# Optional: custom directory for persisted per-chat pi sessions.
# Defaults to ./.pi/telegram-sessions
PI_SESSION_DIR=

# Optional: comma-separated directories that pi may send as Telegram file attachments
# via the telegram_queue_attachment tool. Relative paths are resolved from PI_WORKDIR.
# Defaults to PI_WORKDIR only.
TELEGRAM_ATTACHMENT_ROOTS=

# Required for the local Postgres MCP package if enabled in .mcp.json.
DATABASE_URL=

# Required for the local Datadog MCP package if enabled in .mcp.json.
DD_API_KEY=
DD_APP_KEY=

# Optional Datadog site override, for example datadoghq.com or us5.datadoghq.com.
DD_SITE=
